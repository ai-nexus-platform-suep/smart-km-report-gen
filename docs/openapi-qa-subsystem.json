{
  "openapi": "3.0.1",
  "info": {
    "title": "知识问答子系统API",
    "description": "智能问答服务 + 模型配置管理。Python 智能体 (:8000) 和 Java 配置服务 (:8082)。",
    "version": "1.1.0"
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Python 智能体 (会话/聊天)"
    },
    {
      "url": "http://localhost:8082",
      "description": "Java 配置服务 (模型配置管理)"
    }
  ],
  "tags": [
    { "name": "Conversation", "description": "会话管理" },
    { "name": "Chat", "description": "智能对话" },
    { "name": "ModelConfig", "description": "模型配置管理" }
  ],
  "paths": {
    "/conversations": {
      "post": {
        "summary": "创建会话",
        "tags": ["Conversation"],
        "parameters": [
          {
            "name": "user_id",
            "in": "query",
            "schema": { "type": "integer", "default": 1 }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "title": { "type": "string", "maxLength": 200, "default": "新对话" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [{}, {
                    "type": "object",
                    "properties": { "data": { "$ref": "#/components/schemas/ConversationSchema" } }
                  }]
                }
              }
            }
          }
        }
      },
      "get": {
        "summary": "查询会话列表",
        "tags": ["Conversation"],
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "size", "in": "query", "schema": { "type": "integer", "default": 20 } },
          { "name": "user_id", "in": "query", "schema": { "type": "integer", "default": 1 } }
        ],
        "responses": {
          "200": {
            "description": "分页列表",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [{}, {
                    "type": "object",
                    "properties": {
                      "data": {
                        "type": "object",
                        "properties": {
                          "items": { "type": "array", "items": { "$ref": "#/components/schemas/ConversationSchema" } },
                          "total": { "type": "integer" },
                          "page": { "type": "integer" },
                          "size": { "type": "integer" }
                        }
                      }
                    }
                  }]
                }
              }
            }
          }
        }
      }
    },
    "/conversations/{conversation_id}": {
      "patch": {
        "summary": "修改会话标题",
        "tags": ["Conversation"],
        "parameters": [
          { "name": "conversation_id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["title"],
                "properties": { "title": { "type": "string", "minLength": 1, "maxLength": 200 } }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [{}, {
                    "type": "object",
                    "properties": { "data": { "$ref": "#/components/schemas/ConversationSchema" } }
                  }]
                }
              }
            }
          }
        }
      },
      "delete": {
        "summary": "删除会话 (软删除)",
        "tags": ["Conversation"],
        "parameters": [
          { "name": "conversation_id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "成功" },
          "404": { "description": "会话不存在" }
        }
      }
    },
    "/conversations/{conversation_id}/messages": {
      "get": {
        "summary": "查询会话历史消息",
        "tags": ["Conversation"],
        "parameters": [
          { "name": "conversation_id", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "size", "in": "query", "schema": { "type": "integer", "default": 50 } }
        ],
        "responses": {
          "200": {
            "description": "消息列表",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [{}, {
                    "type": "object",
                    "properties": {
                      "data": {
                        "type": "object",
                        "properties": {
                          "session_id": { "type": "integer" },
                          "title": { "type": "string" },
                          "total": { "type": "integer" },
                          "messages": { "type": "array", "items": { "$ref": "#/components/schemas/MessageSchema" } }
                        }
                      }
                    }
                  }]
                }
              }
            }
          }
        }
      }
    },
    "/chat/test": {
      "post": {
        "summary": "非持久化测试调用",
        "description": "直接调用 Agent，不写数据库，适合本地调试。",
        "tags": ["Chat"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["question"],
                "properties": {
                  "question": { "type": "string" },
                  "selected_kb_ids": { "type": "array", "items": { "type": "integer" } },
                  "user_id": { "type": "integer", "nullable": true },
                  "messages": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "role": { "$ref": "#/components/schemas/MessageRole" },
                        "content": { "type": "string" }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Agent 运行结果",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "intent": { "$ref": "#/components/schemas/IntentType" },
                    "mode": { "type": "string" },
                    "needs_clarification": { "type": "boolean" },
                    "retrieved_docs_count": { "type": "integer" },
                    "thinking_steps": { "type": "array", "items": { "type": "object" } },
                    "citations": { "type": "array", "items": { "type": "object" } },
                    "final_response": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/chat": {
      "post": {
        "summary": "发送流式消息 (SSE)",
        "description": "持久化会话聊天，通过 SSE 返回结果。事件: thinking, message, citation, error, done。",
        "tags": ["Chat"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["conversation_id", "question"],
                "properties": {
                  "conversation_id": { "type": "integer", "format": "int64" },
                  "question": { "type": "string", "minLength": 1 },
                  "user_id": { "type": "integer", "default": 1, "nullable": true },
                  "selected_kb_ids": { "type": "array", "items": { "type": "integer" } }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "SSE 流输出",
            "content": { "text/event-stream": { "schema": { "type": "string" } } }
          },
          "400": { "description": "参数错误" },
          "404": { "description": "会话不存在" }
        }
      }
    },
    "/api/model-configs": {
      "get": {
        "summary": "查询模型配置列表",
        "description": "返回当前用户的模型配置，apiKey 脱敏 (sk-****abcd)",
        "tags": ["ModelConfig"],
        "servers": [{ "url": "http://localhost:8082" }],
        "responses": {
          "200": {
            "description": "配置列表",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [{}, {
                    "type": "object",
                    "properties": {
                      "data": { "type": "array", "items": { "$ref": "#/components/schemas/ModelConfigVO" } }
                    }
                  }]
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "新增模型配置",
        "description": "提交明文 apiKey，AES 加密后落库。场景下首个配置自动设为默认。",
        "tags": ["ModelConfig"],
        "servers": [{ "url": "http://localhost:8082" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["provider", "baseUrl", "modelName", "apiKey"],
                "properties": {
                  "provider": { "type": "string", "example": "deepseek", "enum": ["deepseek", "openai", "qwen", "siliconflow"] },
                  "baseUrl": { "type": "string", "example": "https://api.deepseek.com" },
                  "modelName": { "type": "string", "example": "deepseek-chat" },
                  "apiKey": { "type": "string", "description": "明文 API Key，落库时 AES 加密" },
                  "scenario": { "type": "string", "default": "chat", "enum": ["chat", "report_generate"] }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [{}, {
                    "type": "object",
                    "properties": { "data": { "$ref": "#/components/schemas/ModelConfigVO" } }
                  }]
                }
              }
            }
          }
        }
      }
    },
    "/api/model-configs/{id}": {
      "put": {
        "summary": "修改模型配置",
        "tags": ["ModelConfig"],
        "servers": [{ "url": "http://localhost:8082" }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["provider", "baseUrl", "modelName", "apiKey"],
                "properties": {
                  "provider": { "type": "string", "example": "deepseek", "enum": ["deepseek", "openai", "qwen", "siliconflow"] },
                  "baseUrl": { "type": "string", "example": "https://api.deepseek.com" },
                  "modelName": { "type": "string", "example": "deepseek-chat" },
                  "apiKey": { "type": "string" },
                  "scenario": { "type": "string", "default": "chat", "enum": ["chat", "report_generate"] }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [{}, {
                    "type": "object",
                    "properties": { "data": { "$ref": "#/components/schemas/ModelConfigVO" } }
                  }]
                }
              }
            }
          }
        }
      },
      "delete": {
        "summary": "删除模型配置",
        "tags": ["ModelConfig"],
        "servers": [{ "url": "http://localhost:8082" }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "成功" },
          "403": { "description": "无权操作此配置" }
        }
      }
    },
    "/api/model-configs/{id}/default": {
      "post": {
        "summary": "设为默认配置",
        "description": "事务操作：取消同场景旧默认，设置新默认。",
        "tags": ["ModelConfig"],
        "servers": [{ "url": "http://localhost:8082" }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "成功" }
        }
      }
    },
    "/internal/model-configs/default": {
      "get": {
        "summary": "[内部] 获取默认配置",
        "description": "供 Python 智能体调用，返回解密 apiKey。无需登录。",
        "tags": ["ModelConfig"],
        "servers": [{ "url": "http://localhost:8082" }],
        "parameters": [
          { "name": "userId", "in": "query", "required": true, "schema": { "type": "integer", "example": 1 } },
          { "name": "scenario", "in": "query", "schema": { "type": "string", "default": "chat" } }
        ],
        "responses": {
          "200": {
            "description": "解密后的配置",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [{}, {
                    "type": "object",
                    "properties": { "data": { "$ref": "#/components/schemas/ModelConfigInternalVO" } }
                  }]
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "MessageRole": {
        "type": "string",
        "enum": ["user", "assistant", "system"]
      },
      "GenerateStatus": {
        "type": "integer",
        "enum": [0, 1, 2],
        "description": "0-生成中 1-已完成 2-失败"
      },
      "IntentType": {
        "type": "string",
        "enum": ["CHAT", "KNOWLEDGE_QA", "DOCUMENT_SEARCH", "REPORT_GENERATION", "KB_MANAGEMENT", "TASK_ACTION"]
      },
      "ConversationSchema": {
        "type": "object",
        "properties": {
          "session_id": { "type": "integer", "format": "int64" },
          "title": { "type": "string" },
          "message_count": { "type": "integer" },
          "last_message_at": { "type": "string", "format": "date-time" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "MessageSchema": {
        "type": "object",
        "properties": {
          "message_id": { "type": "integer", "format": "int64" },
          "seq": { "type": "integer" },
          "role": { "$ref": "#/components/schemas/MessageRole" },
          "content": { "type": "string" },
          "intent_type": { "$ref": "#/components/schemas/IntentType", "nullable": true },
          "thinking_steps": { "type": "string", "description": "JSON 数组字符串", "nullable": true },
          "citations": { "type": "string", "description": "JSON 数组字符串", "nullable": true },
          "generate_status": { "$ref": "#/components/schemas/GenerateStatus" },
          "token_usage": { "type": "object", "nullable": true },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "ModelConfigVO": {
        "type": "object",
        "description": "前端视图 (apiKey 脱敏)",
        "properties": {
          "id": { "type": "integer" },
          "userId": { "type": "integer" },
          "provider": { "type": "string", "example": "deepseek" },
          "baseUrl": { "type": "string", "example": "https://api.deepseek.com" },
          "modelName": { "type": "string", "example": "deepseek-chat" },
          "apiKeyMasked": { "type": "string", "description": "脱敏密钥 sk-****abcd" },
          "scenario": { "type": "string", "example": "chat" },
          "enabled": { "type": "integer", "description": "0-禁用 1-启用" },
          "isDefault": { "type": "integer", "description": "0-非默认 1-默认" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "ModelConfigInternalVO": {
        "type": "object",
        "description": "内部视图 (apiKey 明文)",
        "properties": {
          "provider": { "type": "string" },
          "baseUrl": { "type": "string" },
          "modelName": { "type": "string" },
          "apiKey": { "type": "string", "description": "解密后的明文 API Key" },
          "timeoutSeconds": { "type": "integer" }
        }
      }
    }
  }
}
