RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=km
RABBITMQ_PASSWORD=km123456
RABBITMQ_VIRTUAL_HOST=/

DOCUMENT_PROCESSING_EXCHANGE=km.document.processing
DOCUMENT_PROCESSING_QUEUE=km.document.processing.parse
DOCUMENT_PROCESSING_ROUTING_KEY=document.process
DOCUMENT_PROCESSING_DLX=km.document.processing.dlx
DOCUMENT_PROCESSING_DLQ=km.document.processing.dlq
DOCUMENT_PROCESSING_DLQ_ROUTING_KEY=document.process.dead
RABBITMQ_PREFETCH_COUNT=1
MAX_CONCURRENT_PARSE_JOBS=1

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=km-documents
MINIO_SECURE=false

KM_BACKEND_BASE_URL=http://localhost:8091
KM_BACKEND_STATUS_URL=http://localhost:8091/internal/documents/status
KM_AI_SERVICE_WORK_DIR=.work
KM_AI_SKIP_MINERU=false
KM_AI_EMBEDDING_CONFIG_SOURCE=env
KM_AI_EMBEDDING_MODEL_NAME=text-embedding-v4
KM_AI_EMBEDDING_API_URL=https://{WorkspaceId}.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
KM_AI_EMBEDDING_API_KEY=
KM_AI_EMBEDDING_DIMENSION=2048
KM_AI_EMBEDDING_BATCH_SIZE=10
KM_AI_EMBEDDING_TIMEOUT_SECONDS=60

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_SOCKET_TIMEOUT_SECONDS=5
KM_AI_BATCH_REINDEX_STATUS_TTL_SECONDS=86400
KM_AI_BATCH_REINDEX_MAX_ACTIVE_JOBS=1
KM_AI_BATCH_REINDEX_DOCUMENT_CONCURRENCY=2
KM_AI_BATCH_REINDEX_RESULT_LIMIT=200
KM_AI_BATCH_REINDEX_PREFIX=parsed/

QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=km_chunks
QDRANT_TIMEOUT_SECONDS=30

MINERU_BACKEND=agent
MINERU_METHOD=auto
MINERU_LANG=ch
MINERU_AGENT_API_BASE_URL=https://mineru.net/api/v1/agent
MINERU_PAID_API_BASE_URL=https://mineru.net/api/v4
MINERU_API_TOKEN=
MINERU_MODEL_VERSION=vlm
MINERU_PAGE_RANGES=
MINERU_TIMEOUT_SECONDS=600
MINERU_POLL_INTERVAL_SECONDS=2
MINERU_ENABLE_FORMULA=false
MINERU_ENABLE_TABLE=true
