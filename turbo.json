{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "inputs": ["src/**", "vite.config.ts", "tsconfig.json", "index.html"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "preview": {
      "dependsOn": ["build"]
    }
  }
}
