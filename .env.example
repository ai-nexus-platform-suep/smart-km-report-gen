# 知识管理系统 - 环境变量模板
# 复制此文件为 .env 并根据实际环境修改

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=km_db
MYSQL_USER=root
MYSQL_PASSWORD=root

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# MinIO
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# JWT
JWT_SECRET=km-platform-dev-secret-key-do-not-use-in-prod

# SiliconFlow API（嵌入/重排）
SILICONFLOW_API_KEY=sk-your-key-here
