# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=km_db
MYSQL_USER=km
MYSQL_PASSWORD=km123456

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=km
RABBITMQ_PASSWORD=km123456

# MinIO
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=km-documents
KM_STORAGE_TYPE=minio

# Milvus（向量库，大组统一选型）
MILVUS_HOST=localhost
MILVUS_PORT=19530

# km-ai-service（Python：chunk / embed / rerank）
KM_AI_SERVICE_URL=http://localhost:8092
KM_BACKEND_STATUS_URL=http://localhost:8091/internal/documents/status
DOCUMENT_PROCESSING_EXCHANGE=km.document.processing
DOCUMENT_PROCESSING_QUEUE=km.document.processing.parse
DOCUMENT_PROCESSING_ROUTING_KEY=document.process
DOCUMENT_PROCESSING_DLX=km.document.processing.dlx
DOCUMENT_PROCESSING_DLQ=km.document.processing.dlq
DOCUMENT_PROCESSING_DLQ_ROUTING_KEY=document.process.dead
RABBITMQ_PREFETCH_COUNT=1
MAX_CONCURRENT_PARSE_JOBS=1
KM_AI_SKIP_MINERU=false
KM_AI_SERVICE_WORK_DIR=km-ai-service/.work
MINERU_TIMEOUT_SECONDS=600

# MinerU / parser runtime used by km-ai-service worker
MINERU_BACKEND=pipeline
MINERU_ENABLE_FORMULA=false
MINERU_ENABLE_TABLE=true
# Keep image analysis disabled for local MVP; km-ai-service does not upload MinerU image artifacts.
MINERU_ENABLE_IMAGE_ANALYSIS=false
MINERU_MODEL_SOURCE=modelscope
PIP_CACHE_DIR=km-ai-service/.cache/pip
TEMP=km-ai-service/.tmp
TMP=km-ai-service/.tmp
HF_HOME=km-ai-service/.cache/huggingface
HUGGINGFACE_HUB_CACHE=km-ai-service/.cache/huggingface/hub
MODELSCOPE_CACHE=km-ai-service/.cache/modelscope
MINERU_TOOLS_CONFIG_JSON=km-ai-service/.mineru/mineru.json

# JWT
JWT_SECRET=change-me-in-production-km-platform-2026
JWT_EXPIRE_HOURS=24

# SiliconFlow（由 km-ai-service 使用）
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
