# 复制本文件为 .env 后填写真实值（.env 不要提交到 Git）
# 文件位置：qa-agent/.env

# ---- 数据库 ----
DATABASE_URL=mysql+aiomysql://root:1234@127.0.0.1:3306/smart_km_report_gen


# ---- LLM (DeepSeek) ----
LLM_API_URL=https://api.deepseek.com
# ↓↓↓ DeepSeek 密钥填在这里（在 https://platform.deepseek.com 申请） ↓↓↓
LLM_API_KEY=
# ↑↑↑ 把 sk-your-deepseek-api-key 换成你的真实 Key ↑↑↑
LLM_MODEL_NAME=deepseek-chat
LLM_TIMEOUT=60

# ---- Embedding（可选，暂未使用）----
EMBEDDING_API_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL_NAME=

# ---- 知识库检索服务 ----
KNOWLEDGE_SEARCH_URL=http://127.0.0.1:8083/api/knowledge/search

