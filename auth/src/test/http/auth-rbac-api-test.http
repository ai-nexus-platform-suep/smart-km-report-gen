### ================================================================
### Auth & RBAC 接口自动化测试（IntelliJ / VS Code REST Client）
### ================================================================
### 用法:
###   1. 执行 init.sql，启动 auth(8081) + gateway(8080)
###   2. 安装 REST Client 插件，打开本文件
###   3. 从「0. 环境检查」起顺序 Run All 或逐个运行
### 账号: superadmin / admin / user  密码: admin123
### ================================================================

@baseUrl = http://localhost:8080
@authDirectUrl = http://localhost:8081
@password = admin123

### ================================================================
### 0. 超管登录（写入全局变量）
### ================================================================
# @name login_superadmin
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "username": "superadmin",
  "password": "{{password}}"
}

> {%
    client.test("超管登录 200", function() {
        client.assert(response.status === 200, "status=" + response.status);
        client.assert(response.body.code === 200, "code=" + response.body.code);
        client.assert(response.body.data.accessToken, "missing accessToken");
        client.assert(response.body.data.permissions.includes("auth:role:manage"), "missing auth:role:manage");
    });
    client.global.set("superadminToken", response.body.data.accessToken);
    client.global.set("superadminRefresh", response.body.data.refreshToken);
%}

### ================================================================
### 1. 公开注册
### ================================================================
# @name register_public
POST {{baseUrl}}/api/auth/register
Content-Type: application/json

{
  "username": "rest_test_user",
  "password": "123456",
  "email": "test@example.com",
  "phone": "13800138001"
}

> {%
    client.test("注册 201，返回用户信息", function() {
        client.assert(response.status === 201, "status=" + response.status);
        client.assert(response.body.code === 200, "code=" + response.body.code);
        client.assert(response.body.data.id != null, "missing id");
        client.assert(response.body.data.username === "rest_test_user", "username mismatch");
        client.assert(response.body.data.roles.indexOf("ROLE_USER") >= 0, "missing ROLE_USER");
    });
%}

### 1b. 注册不含可选字段（向后兼容）
# @name register_minimal
POST {{baseUrl}}/api/auth/register
Content-Type: application/json

{
  "username": "rest_test_user2",
  "password": "123456"
}

> {%
    client.test("最小字段注册 201", function() {
        client.assert(response.status === 201, "status=" + response.status);
        client.assert(response.body.data.username === "rest_test_user2", "username mismatch");
    });
%}

### ================================================================
### 2. 三角色登录 + JWT 内容校验
### ================================================================
# @name login_admin
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{"username": "admin", "password": "{{password}}"}

> {%
    client.test("管理员登录", function() {
        client.assert(response.body.code === 200);
        client.assert(response.body.data.roles.includes("ROLE_ADMIN"));
        client.assert(response.body.data.permissions.includes("auth:user:list"));
        client.assert(!response.body.data.permissions.includes("auth:role:manage"));
    });
    client.global.set("adminToken", response.body.data.accessToken);
%}

###
# @name login_user
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{"username": "user", "password": "{{password}}"}

> {%
    client.test("普通用户登录", function() {
        client.assert(response.body.code === 200);
        client.assert(response.body.data.roles.includes("ROLE_USER"));
        client.assert(response.body.data.permissions.includes("chat:conversation:use"));
        client.assert(!response.body.data.permissions.includes("auth:user:list"));
    });
    client.global.set("userToken", response.body.data.accessToken);
%}

### ================================================================
### 3. 当前用户 / 权限 / 菜单
### ================================================================
# @name me_superadmin
GET {{baseUrl}}/api/auth/me
Authorization: Bearer {{superadminToken}}

> {%
    client.test("/me", function() {
        client.assert(response.body.code === 200);
        client.assert(response.body.data.username === "superadmin");
        client.assert(response.body.data.roles.length > 0);
        client.assert(response.body.data.permissions.length > 0);
    });
%}

###
# @name me_permissions
GET {{baseUrl}}/api/auth/me/permissions
Authorization: Bearer {{superadminToken}}

> {%
    client.test("/me/permissions", function() {
        client.assert(response.body.code === 200);
        client.assert(Array.isArray(response.body.data));
    });
%}

###
# @name me_menus_user
GET {{baseUrl}}/api/auth/me/menus
Authorization: Bearer {{userToken}}

> {%
    client.test("/me/menus 普通用户", function() {
        client.assert(response.body.code === 200);
        client.assert(response.body.data.length >= 1);
    });
%}

### ================================================================
### 4. Refresh Token
### ================================================================
# @name refresh_token
POST {{baseUrl}}/api/auth/refresh
Content-Type: application/json

{
  "refreshToken": "{{superadminRefresh}}"
}

> {%
    client.test("刷新 Token", function() {
        client.assert(response.body.code === 200);
        client.assert(response.body.data.accessToken);
        client.assert(response.body.data.refreshToken);
    });
    client.global.set("superadminToken", response.body.data.accessToken);
%}

