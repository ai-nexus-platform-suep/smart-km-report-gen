<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.km.repository.DocumentMapper">

    <resultMap id="BaseResultMap" type="com.km.entity.Document">
        <id column="id" property="id"/>
        <result column="kb_id" property="kbId"/>
        <result column="filename" property="filename"/>
        <result column="file_path" property="filePath"/>
        <result column="file_size" property="fileSize"/>
        <result column="mime_type" property="mimeType"/>
        <result column="status" property="status"/>
        <result column="error_msg" property="errorMsg"/>
        <result column="tags_json" property="tagsJson"/>
        <result column="created_by" property="createdBy"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <sql id="BaseColumns">
        id, kb_id, filename, file_path, file_size, mime_type,
        status, error_msg, tags_json, created_by, created_at, updated_at
    </sql>

    <insert id="insert" parameterType="com.km.entity.Document">
        INSERT INTO document (id, kb_id, filename, file_path, file_size, mime_type,
                              status, error_msg, tags_json, created_by, created_at, updated_at)
        VALUES (#{id}, #{kbId}, #{filename}, #{filePath}, #{fileSize}, #{mimeType},
                #{status}, #{errorMsg}, #{tagsJson}, #{createdBy}, NOW(), NOW())
    </insert>

    <update id="updateById" parameterType="com.km.entity.Document">
        UPDATE document
        <set>
            <if test="filename != null">filename = #{filename},</if>
            <if test="status != null">status = #{status},</if>
            <if test="errorMsg != null">error_msg = #{errorMsg},</if>
            <if test="tagsJson != null">tags_json = #{tagsJson},</if>
            updated_at = NOW()
        </set>
        WHERE id = #{id}
    </update>

    <!-- 专用标签更新，仅改 tags_json，不与 updateStatus 混用 -->
    <update id="updateTags">
        UPDATE document
        SET tags_json = #{tagsJson},
            updated_at = NOW()
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM document WHERE id = #{id}
    </delete>

    <delete id="deleteByIds">
        DELETE FROM document WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <delete id="deleteByKbId">
        DELETE FROM document WHERE kb_id = #{kbId}
    </delete>

    <select id="getById" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns"/>
        FROM document
        WHERE id = #{id}
    </select>

    <select id="listByKbId" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns"/>
        FROM document
        WHERE kb_id = #{kbId}
        <if test="status != null and status != '\''">
            AND status = #{status}
        </if>
        ORDER BY created_at DESC
        LIMIT #{limit} OFFSET #{offset}
    </select>

    <select id="countByKbId" resultType="long">
        SELECT COUNT(*)
        FROM document
        WHERE kb_id = #{kbId}
        <if test="status != null and status != '\''">
            AND status = #{status}
        </if>
    </select>

    <update id="updateStatus">
        UPDATE document
        SET status = #{status},
            error_msg = #{errorMsg},
            updated_at = NOW()
        WHERE id = #{id}
    </update>

    <!-- 批量查询文档，用于检索结果回填文档名称 -->
    <select id="listByIds" resultMap="BaseResultMap">
        SELECT <include refid="BaseColumns"/>
        FROM document
        WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>

    <!-- 查询指定知识库下状态为 READY 的文档 ID 列表 -->
    <!-- 用于 EPIC-05 BM25 降级搜索 -->
    <select id="listReadyDocIdsByKbIds" resultType="string">
        SELECT id
        FROM document
        WHERE kb_id IN
        <foreach collection="kbIds" item="kbId" open="(" separator="," close=")">
            #{kbId}
        </foreach>
        AND status = '\''READY'\''
    </select>


    <!-- 查询全部 READY 状态文档 ID，BM25 全库降级搜索 -->
    <select id="listAllReadyDocIds" resultType="string">
        SELECT id
        FROM document
        WHERE status = 'READY'
    </select>

</mapper>