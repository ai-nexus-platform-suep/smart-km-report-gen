<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.km.repository.ChunkMapper">

    <resultMap id="BaseMap" type="com.km.entity.Chunk">
        <id column="id" property="id"/>
        <result column="doc_id" property="docId"/>
        <result column="content" property="content"/>
        <result column="chapter_path" property="chapterPath"/>
        <result column="chunk_index" property="chunkIndex"/>
        <result column="chunk_type" property="chunkType"/>
        <result column="vector_id" property="vectorId"/>
        <result column="char_count" property="charCount"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <insert id="batchInsert">
        INSERT INTO chunk (id, doc_id, content, chapter_path, chunk_index, chunk_type, vector_id, char_count, created_at)
        VALUES
        <foreach collection="chunks" item="c" separator=",">
            (#{c.id}, #{c.docId}, #{c.content}, #{c.chapterPath}, #{c.chunkIndex},
             #{c.chunkType}, #{c.vectorId}, #{c.charCount}, #{c.createdAt})
        </foreach>
    </insert>

    <delete id="deleteByDocId">DELETE FROM chunk WHERE doc_id = #{docId}</delete>
    <delete id="deleteByKbId">
        DELETE c FROM chunk c JOIN document d ON c.doc_id = d.id WHERE d.kb_id = #{kbId}
    </delete>

    <select id="listByDocId" resultMap="BaseMap">
        SELECT * FROM chunk WHERE doc_id = #{docId} ORDER BY chunk_index ASC LIMIT #{limit} OFFSET #{offset}
    </select>

    <select id="countByDocId" resultType="long">
        SELECT COUNT(*) FROM chunk WHERE doc_id = #{docId}
    </select>

    <select id="countAll" resultType="long">SELECT COUNT(*) FROM chunk</select>

</mapper>
